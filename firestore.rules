rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'rahamansgmadil2@gmail.com';
    }

    // Movie validation
    function isValidMovie(data) {
      return data.keys().hasAll(['title', 'videoUrl', 'thumbnailUrl', 'createdAt', 'createdBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.videoUrl is string && data.videoUrl.size() > 0 && data.videoUrl.size() <= 1000 &&
             data.thumbnailUrl is string && data.thumbnailUrl.size() > 0 && data.thumbnailUrl.size() <= 1000 &&
             (isAdmin() || data.createdAt == request.time) &&
             (isAdmin() || data.createdBy == request.auth.uid) &&
             (data.get('description', '') is string && data.get('description', '').size() <= 2000) &&
             (data.get('duration', '') is string && data.get('duration', '').size() <= 50) &&
             (data.get('year', '') is string && data.get('year', '').size() <= 10) &&
             (data.get('rating', '') is string && data.get('rating', '').size() <= 10) &&
             (data.get('trailerUrl', '') is string && data.get('trailerUrl', '').size() <= 1000) &&
             (data.get('logoUrl', '') is string && data.get('logoUrl', '').size() <= 1000);
    }

    // Progress validation
    function isValidProgress(data) {
      return data.keys().hasAll(['movieId', 'userId', 'progress', 'duration', 'lastWatched']) &&
             data.movieId is string &&
             data.userId == request.auth.uid &&
             data.progress is number &&
             data.duration is number &&
             data.lastWatched == request.time;
    }

    match /movies/{movieId} {
      allow read: if true; 
      
      allow create: if isSignedIn() && (isAdmin() || (isEmailVerified() && isValidId(movieId) && isValidMovie(incoming())));
      
      allow update: if (isOwner(existing()) || isAdmin()) && 
                    (isAdmin() || (
                      isEmailVerified() && 
                      isValidMovie(incoming()) &&
                      incoming().createdBy == existing().createdBy &&
                      incoming().createdAt == existing().createdAt
                    ));
                    
      allow delete: if (isOwner(existing()) || isAdmin());
    }

    match /userProgress/{progressId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(progressId) && isValidProgress(incoming());
      allow update: if isSignedIn() && isValidProgress(incoming()) && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
